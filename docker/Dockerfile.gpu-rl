# syntax=docker/dockerfile:1
#
# Docker image for RL training with MarinSkyRL (skyrl-train)
#
# This image includes a SEPARATE RL environment due to dependency conflicts with
# the datagen/base stack (see hpc/rl_requirements.txt: "INCOMPATIBLE with the
# datagen environment"):
#   - RL (MarinSkyRL skyrl-train[vllm]): torch==2.11.0+cu128, vllm==0.20.2rc0
#     (OUR FORK, built FROM SOURCE), ray==2.51.1
#   - base/datagen:                      torch 2.9.x, vllm 0.16.x
# The dual-venv split is therefore KEPT (the conflict is now WIDER than before —
# RL torch 2.11 / vllm-fork-0.20.2rc0 vs base torch 2.9 / vllm 0.16, so the two
# stacks still cannot share a venv).
#
# The RL environment is installed at /opt/openthoughts/envs/rl.
# MarinSkyRL is cloned to /opt/skyrl (for examples/terminal_bench entrypoints).
#
# DEPS-ONLY image (see docker/build_and_push.sh): contains dependencies only,
# never the live source. Source is synced at runtime via SkyPilot to /sky/workdir
# and PYTHONPATH is set so the synced clone wins over anything baked here.
#
# =============================================================================
# WHEEL-CACHE BUILD (fast rebuilds) — see docker/README.gpu-rl-wheelcache.md
# =============================================================================
# The two SLOW steps in this image are the from-source CUDA/x86 nvcc compiles of:
#   - the vLLM FORK (cutlass GEMM kernels — heavy), and
#   - flash-attn 2.8.3 (its flash_attn_2_cuda extension).
# These are NOW isolated into a dedicated `wheel-builder` stage that emits
# RELOCATABLE WHEELS (`vllm-*.whl`, `flash_attn-*.whl`). The main `rl` stage then
# `uv pip install`s those wheels instead of recompiling, so a rebuild that does
# NOT change a source pin or the ABI re-uses the prebuilt wheels and skips nvcc
# entirely.
#
# Two ways the main stage gets the wheels (it tries the cache first):
#   (A) PREBUILT WHEELHOUSE (the durable win): `docker/build_wheels.sh` runs the
#       heavy compiles ONCE and exports the wheels to `docker/wheelhouse/` on the
#       build host (gitignored — large binaries). The main build COPYs them in
#       and installs them: NO nvcc runs. Re-run build_wheels.sh only when a pin
#       or ABI below changes (its MANIFEST records the cache key).
#   (B) FALLBACK in-build compile: if `docker/wheelhouse/` is empty, the
#       `wheel-builder` stage compiles the wheels in-image (one-time cost; buildx
#       layer-caches it for the next rebuild on the same builder).
#
# CACHE KEY (what invalidates a wheel) = the tuple
#   { VLLM_FORK_COMMIT, FLASH_ATTN_VERSION, torch 2.11.0, CUDA 12.8, cp312,
#     x86_64, TORCH_CUDA_ARCH_LIST "8.0;9.0" }.
# Change any of these -> rebuild the wheels (build_wheels.sh rebuilds + rewrites
# the MANIFEST). torchtitan is pure-python (trivial) and is NOT wheel-cached.
# =============================================================================
#
# =============================================================================
# Version pins TRACK THE LIVE JUPITER PRODUCTION STACK (the from-source SIF),
# NOT the portable uv.lock. Ground truth for each pin:
#   - torch 2.11.0+cu128  : MarinSkyRL skyrl-train/pyproject.toml `vllm` extra
#       (`torch==2.11.0`, comment "MIRROR the production SIF
#       skyrl_megatron_vllm0202rc0_r3.sif … torch 2.11.0, vLLM 0.20.2rc0"); and
#       the vLLM fork's requirements/cuda.txt (`torch==2.11.0`). A Leonardo
#       from-source build of this same fork commit independently PROVED the fork
#       REQUIRES torch 2.11.0 — its `_C_stable_libtorch` extension uses the
#       `TORCH_BOX` macro absent from torch 2.9/2.10
#       (agent_logs/2026-06-23_leonardo_eval-qwen35_env_build.md §5).
#   - vLLM 0.20.2rc0      : built FROM SOURCE from OUR FORK (no public wheel for
#       the fork's 0.20.2rc0). Fork = mlfoundations/vllm @ penfever/working,
#       PINNED to commit 76259c63a45e57c0d1cbaca3480aae52ebbfccd1 (NOT a floating
#       branch). Same commit the Jupiter/Leonardo envs build.
#   - torchvision 0.26.0  : skyrl-train `vllm` extra + fork requirements/cuda.txt.
#   - flash-attn 2.8.3    : COMPILED FROM SOURCE against this image's torch
#       2.11.0+cu128 / cp312 / x86_64 so its CUDA extension (`flash_attn_2_cuda`)
#       is PRESENT (the prior image installed 2.6.3 with
#       FLASH_ATTENTION_SKIP_CUDA_BUILD=TRUE -> the extension was ABSENT, and a
#       smoke test proved BOTH vLLM's RotaryEmbedding find_spec-guarded import AND
#       the MarinSkyRL FSDP policy's transformers FA2 path require it).
#       WHY 2.8.3 (not skyrl-train's nominal 2.6.3 pin): flash-attn 2.6.3 is
#       mid-2024 and does NOT build cleanly against torch 2.11 (late-2025 ABI).
#       2.8.3 (Jan-2026, the latest release) is the version the community torch-2.11
#       wheel efforts target (Dao-AILab flash-attention issues #2299/#2425,
#       mjun0812/flash-attention-prebuild-wheels v0.9.34 -> torch 2.10/2.11/2.12)
#       AND the version already proven across the Leonardo stack (otagent torch
#       2.9.1 + MarinSkyRL-RL torch 2.8.0 both ship flash_attn 2.8.3; see
#       .claude/ops/leonardo/ENVIRONMENT_MAP.md). API-COMPAT verified: MarinSkyRL
#       only imports `unpad_input`/`pad_input` (bert_padding) +
#       `cross_entropy_loss` (ops.triton) and stars the unpad tail (`*_`) to be
#       version-agnostic across the 2.6 4-tuple / 2.7+ 5-tuple return shapes, so
#       2.8.3 is a drop-in. No prebuilt wheel for torch-2.11 ships on PyPI, and we
#       compile from OUR Dockerfile rather than pull a third-party fork wheel for
#       provenance/ABI safety. (CP path still uses SDPA; flash-attn is the non-CP
#       fallback; vLLM serving uses its OWN bundled vllm_flash_attn built from the
#       fork source — but transformers FA2 + vLLM's rotary find_spec guard both
#       need this extension to actually exist.)
#   - ray 2.51.1          : skyrl-train base deps.
#   - transformers        : fork requirements/common.txt
#       (>=4.56.0, !=5.0..5.4, !=5.5.0); skyrl-train base requires >=4.51.0.
#       The fork's deps resolve transformers within that band.
#   - python 3.12         : skyrl-train requires-python ==3.12.*
#   - CUDA 12.8 (devel)   : matches the pytorch-cu128 wheel index that
#       skyrl-train pins torch/torchvision to (`[tool.uv.sources] torch =
#       {index="pytorch-cu128"}`). The Jupiter prod SIF is a cu130 build, but the
#       *version pins* are index-agnostic and resolve fine against cu128, which
#       also publishes torch-2.11 wheels — and the CoreWeave H100 driver runs
#       cu128 natively. A *devel* base is required (vs the old -runtime base) so
#       `nvcc` is present for the from-source vLLM + flash-attn compiles.
#
# Build is GPU-COUNT-AGNOSTIC and needs no live GPU (only nvcc): the from-source
# vLLM + flash-attn compiles run on a CPU builder. Target platform is linux/amd64
# (x86_64): the production gpu-rl image + CoreWeave H100 nodes are amd64 ONLY.
# =============================================================================

# Single source of truth for the pins, shared by the wheel-builder + main stages
# AND read by docker/build_wheels.sh to compute the cache key. Bump a pin here ->
# the wheels must be rebuilt.
ARG BASE_IMAGE=nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04
ARG TORCH_VERSION=2.11.0
ARG TORCHVISION_VERSION=0.26.0
ARG RAY_VERSION=2.51.1
ARG FLASH_ATTN_VERSION=2.8.3
ARG VLLM_FORK_REPO=https://github.com/mlfoundations/vllm.git
ARG VLLM_FORK_COMMIT=76259c63a45e57c0d1cbaca3480aae52ebbfccd1
# A100 (8.0) + Hopper (9.0): the GPUs that run this image (Leonardo / CoreWeave+Jupiter).
ARG TORCH_CUDA_ARCH_LIST="8.0;9.0"
ARG MAX_JOBS=8
ARG NVCC_THREADS=2
# Selects where the rl stage's /wheels comes from: `prebuilt-wheelhouse` (default,
# = docker/wheelhouse/ populated by build_wheels.sh) or `wheel-builder` (compile
# inline). Global-scope so it is usable in the `FROM ${WHEEL_SOURCE}` alias below.
ARG WHEEL_SOURCE=prebuilt-wheelhouse

# =============================================================================
# STAGE 1: wheel-builder — compile vLLM-fork + flash-attn into RELOCATABLE WHEELS
# -----------------------------------------------------------------------------
# This is the ONLY stage that runs nvcc. It builds a torch-2.11 venv, then emits
#   /wheels/flash_attn-*.whl  and  /wheels/vllm-*.whl
# The main stage installs from these. When docker/wheelhouse/ already holds
# prebuilt wheels, the main stage uses THOSE and this stage's output is unused
# (and buildx can skip rebuilding it). build_wheels.sh targets THIS stage to
# export the wheels to docker/wheelhouse/ once.
# =============================================================================
FROM ${BASE_IMAGE} AS wheel-builder

ARG TORCH_VERSION
ARG TORCHVISION_VERSION
ARG RAY_VERSION
ARG FLASH_ATTN_VERSION
ARG VLLM_FORK_REPO
ARG VLLM_FORK_COMMIT
ARG TORCH_CUDA_ARCH_LIST
ARG MAX_JOBS
ARG NVCC_THREADS

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential cmake ninja-build \
    python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*
RUN pip3 install --upgrade pip uv

ENV UV_HTTP_TIMEOUT=600
ENV UV_RETRIES=5
ENV TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH_LIST}"
ENV MAX_JOBS="${MAX_JOBS}"
ENV NVCC_THREADS="${NVCC_THREADS}"
ENV VLLM_TARGET_DEVICE=cuda

# Build venv with EXACTLY the torch the wheels must be ABI-compatible with. Both
# from-source builds use --no-build-isolation to reuse THIS torch (their build
# backends `import torch` at build time and cannot see a torch installed in the
# same isolated `uv pip install` invocation -> ModuleNotFoundError: torch).
ENV WHEEL_VENV=/opt/wheelbuild/.venv
RUN uv venv --python 3.12 $WHEEL_VENV
RUN . $WHEEL_VENV/bin/activate && \
    uv pip install --extra-index-url https://download.pytorch.org/whl/cu128 \
        --index-strategy unsafe-best-match \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "setuptools_scm" "setuptools>=77.0.3,<81.0.0" "wheel" "packaging" \
        "ninja" "cmake" "psutil" "pip"

WORKDIR /wheels

# (W1) flash-attn 2.8.3 -> wheel. FLASH_ATTENTION_FORCE_BUILD=TRUE so it never
# silently falls back to a (nonexistent) prebuilt torch-2.11 wheel; build only
# the A100+Hopper arches; bound MAX_JOBS/NVCC_THREADS for RAM headroom.
RUN . $WHEEL_VENV/bin/activate && \
    MAX_JOBS=$MAX_JOBS NVCC_THREADS=$NVCC_THREADS \
        TORCH_CUDA_ARCH_LIST="$TORCH_CUDA_ARCH_LIST" \
        FLASH_ATTENTION_FORCE_BUILD=TRUE \
        python -m pip wheel "flash-attn==${FLASH_ATTN_VERSION}" \
            --no-build-isolation --no-cache-dir --no-deps -w /wheels

# (W2) vLLM FORK -> wheel. use_existing_torch.py strips the fork's torch pins so
# it builds against the torch above; rewrite cutlass-dsl[cu13]->cu128; install
# the fork's python deps; then `pip wheel` the fork extension (no-build-
# isolation reuses torch; FetchContent git-clones cutlass/vllm-flash-attn/etc).
ENV VLLM_FORK_DIR=/opt/vllm-fork
RUN git clone $VLLM_FORK_REPO $VLLM_FORK_DIR && \
    git -C $VLLM_FORK_DIR checkout $VLLM_FORK_COMMIT
RUN . $WHEEL_VENV/bin/activate && \
    cd $VLLM_FORK_DIR && \
    python use_existing_torch.py && \
    sed -i 's/^nvidia-cutlass-dsl\[cu13\]>=/nvidia-cutlass-dsl>=/' requirements/cuda.txt && \
    MAX_JOBS=$MAX_JOBS NVCC_THREADS=$NVCC_THREADS TORCH_CUDA_ARCH_LIST="$TORCH_CUDA_ARCH_LIST" \
        VLLM_TARGET_DEVICE=cuda \
        python -m pip wheel . --no-build-isolation --no-deps -w /wheels -v

# Record the cache key alongside the wheels for provenance.
RUN echo "VLLM_FORK_COMMIT=${VLLM_FORK_COMMIT}" >  /wheels/MANIFEST && \
    echo "FLASH_ATTN_VERSION=${FLASH_ATTN_VERSION}" >> /wheels/MANIFEST && \
    echo "TORCH_VERSION=${TORCH_VERSION}" >> /wheels/MANIFEST && \
    echo "TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST}" >> /wheels/MANIFEST && \
    echo "CUDA=12.8 PY=cp312 PLATFORM=linux_x86_64" >> /wheels/MANIFEST && \
    ls -la /wheels

# =============================================================================
# STAGE 2: wheel sources — pick where the rl stage's /wheels comes from
# -----------------------------------------------------------------------------
# build_wheels.sh exports the wheel-builder's wheels to docker/wheelhouse/ (on
# the build host). When that dir holds wheels, the `prebuilt-wheelhouse` stage
# carries them in so the main stage installs the PREBUILT wheels (no nvcc). When
# you have no prebuilt wheelhouse, pass `--build-arg WHEEL_SOURCE=wheel-builder`
# to compile inline (the `wheels` alias below resolves to that stage instead).
#
# `COPY --from` cannot take a variable, so we alias the chosen source via a
# `FROM ${WHEEL_SOURCE} AS wheels` stage (ARG-from-global-scope pattern) and the
# rl stage always COPYs from the fixed `wheels` alias.
# =============================================================================
FROM scratch AS prebuilt-wheelhouse
# docker/wheelhouse/ always exists (committed .keep); when populated by
# build_wheels.sh it also holds vllm-*.whl / flash_attn-*.whl.
COPY docker/wheelhouse/ /wheels/

# Alias: WHEEL_SOURCE (global-scope ARG above) selects prebuilt-wheelhouse
# (default) or wheel-builder. ARG re-stated here so its value is in scope for FROM.
ARG WHEEL_SOURCE
FROM ${WHEEL_SOURCE} AS wheels

# =============================================================================
# STAGE 3: rl — the runtime image (installs from the wheels; NO nvcc here)
# =============================================================================
FROM ${BASE_IMAGE} AS rl

ARG TORCH_VERSION
ARG TORCHVISION_VERSION
ARG RAY_VERSION
ARG TORCH_CUDA_ARCH_LIST

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    build-essential \
    cmake \
    ninja-build \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast package management
RUN pip3 install --upgrade pip uv

# Create base venv for project infrastructure
RUN uv venv --python 3.12 /opt/openthoughts/.venv
ENV VIRTUAL_ENV=/opt/openthoughts/.venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

WORKDIR /opt/openthoughts
COPY pyproject.toml ./
COPY README.md ./
COPY eval ./eval
COPY hpc ./hpc
COPY scripts ./scripts
COPY data ./data
COPY database ./database
COPY sft ./sft
COPY rl ./rl
COPY assets ./assets
COPY build_support.py ./
COPY setup.py ./
COPY CLAUDE.md ./
COPY CONTRIBUTING.md ./
COPY LICENSE.txt ./
COPY docker ./docker
COPY chat_templates ./chat_templates

# Install base project (without conflicting ML dependencies)
ENV UV_HTTP_TIMEOUT=600
ENV UV_RETRIES=5
RUN . /opt/openthoughts/.venv/bin/activate && \
    uv pip install -e ".[cloud]" && \
    uv pip install pyyaml jinja2

# =============================================================================
# MarinSkyRL Repository (cloned BEFORE install — editable installs resolve the
# `skyrl-gym -> ../skyrl-gym` path symlink that uv's [tool.uv.sources] path
# source points at; installing from a git URL would instead pull skyrl-gym from
# PyPI). This mirrors hpc/setup_rl_env.sh (clone -> editable skyrl-gym ->
# editable skyrl-train).
# =============================================================================
# The installable package is skyrl-train/ (import name `skyrl_train`).
# Runtime entrypoint module: skyrl_train.entrypoints.main_base.
ENV SKYRL_HOME=/opt/skyrl
ENV SKYRL_BRANCH=penfever/working
# Pin to a COMMIT (not the floating branch HEAD) for a deterministic image.
# 78d83a5 = current penfever/working HEAD. Supersedes 2d9feef; the delta adds the
# two fixes that deterministically crashed CoreWeave RL at build_models:
#   - 518179d "fix(moe): default norm_topk_prob=True for Qwen3.5/3.6 MoE (config
#     dropped the field; matches vLLM)" — the MoE 30B/35B arms no longer crash on
#     the missing norm_topk_prob default.
#   - 0b2b05b "fix(fsdp+megatron): retry-with-backoff around rank-0 HF weight-index
#     resolution (transient EOF flake killed multi-node gangs)" — HF weight-
#     resolution retry, so a transient EOF no longer kills a multi-node gang.
# (Still includes 2d9feef's trials_dir raw-str fix; pinning keeps the image
# reproducible.)
ENV SKYRL_COMMIT=78d83a589760d561ff3510dcad0e66f9c24305f1

RUN git clone --branch $SKYRL_BRANCH https://github.com/marin-community/MarinSkyRL.git $SKYRL_HOME && \
    git -C $SKYRL_HOME checkout $SKYRL_COMMIT

# The vLLM fork clone is still needed for requirements/common.txt + cuda.txt (the
# fork's python deps: flashinfer/xgrammar/etc.) — but it is NO LONGER COMPILED
# here. The compiled extension comes in as a prebuilt wheel below.
ENV VLLM_FORK_REPO=https://github.com/mlfoundations/vllm.git
ENV VLLM_FORK_COMMIT=76259c63a45e57c0d1cbaca3480aae52ebbfccd1
ENV VLLM_FORK_DIR=/opt/vllm-fork
RUN git clone $VLLM_FORK_REPO $VLLM_FORK_DIR && \
    git -C $VLLM_FORK_DIR checkout $VLLM_FORK_COMMIT

# =============================================================================
# RL Environment Setup (separate venv due to dependency conflicts)
# =============================================================================
ENV RL_ENV_DIR=/opt/openthoughts/envs/rl

# Create RL environment with Python 3.12 (MarinSkyRL pins requires-python ==3.12.*)
RUN uv venv --python 3.12 $RL_ENV_DIR

ENV TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH_LIST}"

# Bring in the WHEELS from the `wheels` alias (= prebuilt-wheelhouse by default,
# or wheel-builder when built with --build-arg WHEEL_SOURCE=wheel-builder). The
# default path requires docker/build_wheels.sh to have populated the wheelhouse.
COPY --from=wheels /wheels /wheels

# (1) Pin the EXACT live-Jupiter stack FIRST (torch 2.11.0+cu128 from the cu128
#     wheel index, torchvision 0.26.0, ray 2.51.1, transformers in the fork's
#     accepted band). This constrains the resolver so nothing below renudges torch.
RUN . $RL_ENV_DIR/bin/activate && \
    uv pip install --extra-index-url https://download.pytorch.org/whl/cu128 \
        --index-strategy unsafe-best-match \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "ray[default]==${RAY_VERSION}" \
        "transformers>=4.56.0,!=5.0.*,!=5.1.*,!=5.2.*,!=5.3.*,!=5.4.*,!=5.5.0" \
        "setuptools_scm" "setuptools>=77.0.3,<81.0.0" "wheel" "packaging" "ninja" "cmake" "psutil"

# (2) flash-attn: install the PREBUILT wheel (no compile). Assert the CUDA
#     extension `flash_attn_2_cuda` is present (this is exactly what the prior
#     SKIP_CUDA_BUILD image lacked, and what vLLM's rotary find_spec guard +
#     MarinSkyRL's transformers FA2 path both require to EXIST).
RUN . $RL_ENV_DIR/bin/activate && \
    uv pip install --no-deps /wheels/flash_attn-*.whl && \
    python -c "import flash_attn, flash_attn_2_cuda; print('flash_attn', flash_attn.__version__, '+ flash_attn_2_cuda OK (from cached wheel)')"

# (3) vLLM FORK: install the fork's python deps from its requirements, then the
#     PREBUILT vllm wheel (no compile). The deps install (common.txt + cuda.txt)
#     pulls flashinfer/xgrammar/etc.; the cutlass-dsl[cu13]->cu128 rewrite mirrors
#     the fork's own docker. --no-deps on the wheel itself so it does not re-resolve
#     torch/flash-attn.
RUN . $RL_ENV_DIR/bin/activate && \
    cd $VLLM_FORK_DIR && \
    python use_existing_torch.py && \
    sed -i 's/^nvidia-cutlass-dsl\[cu13\]>=/nvidia-cutlass-dsl>=/' requirements/cuda.txt && \
    uv pip install -r requirements/common.txt -r requirements/cuda.txt && \
    uv pip install --no-deps /wheels/vllm-*.whl

# (4) skyrl-gym + skyrl-train (editable, NO [vllm] extra — torch/vllm/flash-attn
#     already provided above), the OT-Agent project, and assert imports resolve.
RUN . $RL_ENV_DIR/bin/activate && \
    uv pip install -e "$SKYRL_HOME/skyrl-gym" --no-build-isolation && \
    uv pip install -e "$SKYRL_HOME/skyrl-train" --no-build-isolation && \
    uv pip install Jinja2 pyyaml omegaconf "hydra-core>=1.3.2" wandb && \
    uv pip install boto3 && \
    uv pip install -e /opt/openthoughts && \
    python -c "import torch, vllm, skyrl_train, flash_attn, flash_attn_2_cuda, boto3; print('torch', torch.__version__, 'vllm', vllm.__version__, 'flash_attn', flash_attn.__version__, 'boto3', boto3.__version__, '+ flash_attn_2_cuda OK')" && \
    echo "baked MarinSkyRL HEAD: $(git -C $SKYRL_HOME rev-parse HEAD)"

# (4a) torchtitan — REQUIRED for MoE expert-parallel (EP>1). MarinSkyRL's
# `apply_ep` (skyrl-train/skyrl_train/distributed/fsdp_utils.py) imports
# `torchtitan.distributed.expert_parallel.ExpertParallel` whenever
# expert_model_parallel_size > 1 (our 30B-A3B 131k and 35B configs run EP=8).
# Without it every EP>1 MoE RL run dies at init_model with
# `ModuleNotFoundError: No module named 'torchtitan'` (weights load fine first;
# the crash is purely this missing dep). This is the `ep` extra of skyrl-train's
# pyproject.toml, which the deps-only build above does NOT pull (we install
# skyrl-train without extras).
#
# REF: git rev a1fdd7e of github.com/pytorch/torchtitan — the EXACT pin
# skyrl-train declares (pyproject.toml: torchtitan = { git=".../torchtitan",
# rev = "a1fdd7e" }; comment: "Pin matches prime-rl (EP + grouped-GEMM + R3
# validated there)"). Verified at this rev: torchtitan/distributed/
# expert_parallel.py defines `class ExpertParallel(ParallelStyle)` — exactly the
# import apply_ep needs.
#
# TORCH-2.11 COMPAT + WHY --no-deps + WHY tyro IS STILL NEEDED:
# torchtitan is pure-python (the EP path only uses torch.distributed.tensor APIs)
# and at a1fdd7e its pyproject pins NO torch, so it does NOT rebuild or renudge our
# from-source torch 2.11.0 / vLLM-fork / flash-attn stack. We install --no-deps so
# its UNRELATED transitive deps (torchdata/datasets/tokenizers/tensorboard/...)
# cannot re-resolve and clobber a protected package in this carefully-pinned RL
# venv. BUT `torchtitan/__init__.py` is EAGER: importing the package (even just
# `torchtitan.distributed.expert_parallel`) runs __init__ -> quantization/float8.py
# -> config/manager.py -> `import tyro`. `tyro` is NOT a transitive of torch/
# transformers/datasets, so a bare `--no-deps torchtitan` leaves it ABSENT and the
# ExpertParallel import-assert below dies with `ModuleNotFoundError: No module
# named 'tyro'` (the production Jupiter SIF ships torchtitan 0.2.2 WITH tyro; the
# skyrl-train `[ep]` extra installs torchtitan WITH deps). So we install tyro
# EXPLICITLY. Install tyro WITH its deps (it itself eager-imports
# docstring-parser/rich/shtab/typing-extensions — a bare `--no-deps tyro` would
# just move the ModuleNotFoundError one hop), but install torchtitan --no-deps (so
# torchtitan's heavy/unrelated dep set can't clobber a protected package). tyro's
# deps are light pure-python and don't touch torch/transformers/numpy/flash-attn.
# torchtitan+tyro are pure-python (trivial) -> NOT wheel-cached (only vLLM/flash-
# attn, the nvcc compiles, are). This step stays cheap on every rebuild.
RUN . $RL_ENV_DIR/bin/activate && \
    uv pip install "tyro" && \
    uv pip install --no-deps \
        "torchtitan @ git+https://github.com/pytorch/torchtitan.git@a1fdd7e" && \
    python -c "from torchtitan.distributed.expert_parallel import ExpertParallel; print('torchtitan ExpertParallel import OK (apply_ep EP>1 unblocked)')"

# (4b) Pin harbor to a COMMIT (deterministic image). The OT-Agent project dep
# (pyproject.toml) installs harbor from a FLOATING branch
# (marin-community/harbor@penfever/working), which is left floating for the rest
# of the stack — but for THIS image we re-install harbor at an immutable commit so
# the build is reproducible and we KNOW which harbor is baked.
#   f7f51f13 = "Merge feuer/silence-litellm-spam: suppress litellm Provider List
#   / debug-info footers" — the current penfever/working HEAD. Its history also
#   carries the TrialNotScoredError de-flatten (stop flattening upstream errors
#   into VNC) and the earlier reward-zeroing rmtree fix (342729d5).
# --no-deps so this only swaps the harbor source, not its resolved deps.
ENV HARBOR_COMMIT=f7f51f131577e0d6672ef815a555b507e83778a0
RUN . $RL_ENV_DIR/bin/activate && \
    uv pip install --no-deps --force-reinstall \
        "harbor[daytona] @ git+https://github.com/marin-community/harbor.git@${HARBOR_COMMIT}" && \
    python -c "import harbor, importlib.metadata as m; print('baked harbor', m.version('harbor'))" && \
    echo "baked harbor commit: ${HARBOR_COMMIT}"

# Set up PYTHONPATH for MarinSkyRL.
# `/sky/workdir` (runtime-synced source) is prepended by the launcher so it wins;
# here we ensure the baked clone's package root (skyrl-train/) and the project
# root are importable as a fallback.
ENV PYTHONPATH="$SKYRL_HOME/skyrl-train:/opt/openthoughts"

# =============================================================================
# Environment Configuration
# =============================================================================
# Set DCFT to project root for HPC utilities
ENV DCFT=/opt/openthoughts
ENV DCFT_RL_ENV=$RL_ENV_DIR

# Increase file descriptor limit
RUN echo "ulimit -n 65535" >> /etc/profile.d/openthoughts-ulimit.sh

# Create activation helper
RUN echo '#!/bin/bash\nsource /opt/openthoughts/envs/rl/bin/activate\nexec "$@"' > /usr/local/bin/rl-env && \
    chmod +x /usr/local/bin/rl-env

CMD ["bash"]
