# Jupiter uses /e/ paths instead of /p/ paths
export SCRATCH=/e/scratch/jureap59/$USER
export DCFT=$SCRATCH/OpenThoughts-Agent
# export SSH_KEY=$HOME/.ssh/authorized_keys/id_ed25519_jsc
# Use the personal feuer1-owned namespace, not the shared /ot dir.
# /ot is owned by nezhurina1 with 777 perms but its child dirs (e.g.
# hf_hub/xet/.../shard-session created by other users) are 755 and
# cause "Permission denied" failures on HF Xet uploads, dataset cache
# lock files, etc. ot-baf is feuer1-owned end-to-end.
export DCFT_DATA=/e/data1/datasets/playground/ot-baf
export DCFT_SCRATCH=/e/scratch/jureap59/$USER/otagent
export DC_AGENT_SECRET_ENV=~/secrets.env
export DCFT_GROUP=jureap59
export WANDB_PROJECT=OpenThoughts-Agent
export HF_HUB_CACHE=$DCFT_DATA/hf_hub
export HF_HOME=$DCFT_DATA/hf_hub
export CHECKPOINTS_DIR=$DCFT_DATA/checkpoints
export MODELS_DIR=$HF_HUB_CACHE
export DATASETS_DIR=$HF_HUB_CACHE
export TOKENIZED_DATASETS_DIR=$DCFT_SCRATCH/tokenized_datasets
export VLLM_CACHE_ROOT=$DCFT_DATA/vllm
# TRITON_CACHE_DIR is set by hpc/shell_utils/triton_cache.sh to use node-local /tmp
export LD_LIBRARY_PATH=/.singularity.d/libs:/usr/local/cuda/compat/lib.real:/usr/local/cuda-13/lib64/stubs:/usr/local/cuda/lib64/stubs:/usr/local/cuda-13/compat/lib.real/:$LD_LIBRARY_PATH 
export IMAGE=/e/scratch/jureap59/ot/containers/dcft_arm.sif
export DISABLE_VERSION_CHECK=1
# SkyRL home directory (cloned by setup_rl_env.sh from https://github.com/penfever/SkyRL.git)
# Resolves to {SkyRL, MarinSkyRL} under the parent (honors $RL_REPO_DIR override);
# falls back to .../SkyRL for byte-identical back-compat. See resolve_rl_repo.sh.
source "${DCFT_PRIVATE:-$DCFT}/hpc/shell_utils/resolve_rl_repo.sh"
export SKYRL_HOME="$(resolve_rl_repo_dir "$DCFT")"
# Keep the repo importable even if Python strips the working directory from sys.path.
# Include SKYRL_HOME/skyrl-train for examples/terminal_bench entrypoints
export PYTHONPATH="${SKYRL_HOME}/skyrl-train:${DCFT_PRIVATE:-$DCFT}${PYTHONPATH:+:$PYTHONPATH}"
# Your personal email address for notifications
# export EMAIL_ADDRESS="bf996@nyu.edu"
# NOTE: Do NOT set TMPDIR to shared scratch. HF datasets arrow caches use
# tempfile and race-condition on NFS when multiple ranks write simultaneously.
# Keep TMPDIR as local /tmp (per-node). The triton_cache.sh script handles
# Triton kernel caches separately.
export WANDB_MODE=offline